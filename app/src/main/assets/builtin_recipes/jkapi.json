{
  "schemaVersion": 1,
  "id": "jkapi",
  "displayName": "JKAPI (无铭API)",
  "version": "1.0.0",
  "supportedPlatforms": ["NETEASE", "QQ"],

  "auth": [
    { "key": "apiKey", "label": "API 密钥", "required": true, "type": "password" }
  ],

  "platformVars": {
    "NETEASE": { "platCode": "wy" },
    "QQ": { "platCode": "qq" }
  },

  "qualityMap": {
    "128k": "128",
    "320k": "320",
    "flac": "flac"
  },

  "request": {
    "method": "GET",
    "url": "https://jkapi.com/api/music?plat={{platformVars.platCode}}&apiKey={{auth.apiKey}}&name={{encodeURIComponent(title)}} {{encodeURIComponent(artist)}}",
    "headers": {},
    "body": null,
    "timeoutSeconds": 15,
    "followRedirects": true
  },

  "extract": {
    "kind": "json_path",
    "successCondition": { "path": "code", "equals": 1 },
    "playableUrlPath": "musicUrl",
    "errorMessagePath": "msg"
  },

  "validate": {
    "titleSimilarity": { "responsePath": "name", "trackField": "title", "min": 0.4 }
  }
}
